    {
      "id": "bz9SFdsXWCS7tkoKVrX3-",
      "type": "text",
      "x": 1629.2367831059978,
      "y": 274.6913438873211,
      "width": 248.078125,
      "height": 129.60000000000002,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 721247933,
      "version": 338,
      "versionNonce": 1501451165,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783558234431,
      "link": null,
      "locked": false,
      "text": "บริการแบบจบในที่เดียว (One-Stop\nEvent Gear)\nได้ทั้งเสื้อและของรางวัลคัสตอม,\nไม่มีขั้นต่ำในการสั่งผลิตถ้วยรางวัลด้วย\nเทคโนโลยี 3D Printing,\nระบบสั่งซื้อและอัพโหลดลายที่ง่ายดาย",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "wbPkiIazu_-bXp7Z3bHpN",
      "originalText": "บริการแบบจบในที่เดียว (One-Stop Event Gear) ได้ทั้งเสื้อและของรางวัลคัสตอม, ไม่มีขั้นต่ำในการสั่งผลิตถ้วยรางวัลด้วยเทคโนโลยี 3D Printing, ระบบสั่งซื้อและอัพโหลดลายที่ง่ายดาย",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "K5fgvlCatd44NqrtSekdN",
      "type": "rectangle",
      "x": 1930.5102693006252,
      "y": 267.1219227322855,
