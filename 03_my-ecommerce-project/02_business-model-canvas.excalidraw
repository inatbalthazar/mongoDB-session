    {
      "id": "3a4vUrdLDiYo5v_D1Tkbo",
      "type": "text",
      "x": 1935.5102693006252,
      "y": 272.1219227322855,
      "width": 246.1640625,
      "height": 108,
      "angle": 0,
      "strokeColor": "#1e1e1e",
