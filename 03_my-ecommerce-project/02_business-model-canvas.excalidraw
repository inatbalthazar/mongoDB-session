    },
    {
      "id": "05X27KSFuHnf2JKBu8GEa",
      "type": "text",
      "x": 1028.5268765194933,
      "y": 920.6161693234512,
      "width": 506.1548156738281,
      "height": 64.80000000000001,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aH",
      "roundness": null,
      "seed": 12536861,
      "version": 657,
      "versionNonce": 1632841501,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783558729564,
      "link": null,
      "locked": false,
      "text": "ต้นทุนวัตถุดิบ (เสื้อเปล่า, เส้นพลาสติก), ค่าไฟและค่าบำรุงรักษาเครื่องพิมพ์/3D\nPrinter, ค่าการตลาดออนไลน์,ค่าเช่าคลังสินค้า, ค่าเช่า Hosting Domain,\nเงินเดือนทีมงานและแอดมิน, ภาษีฯ",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "mtAMQjRssjNTjd9ct0tKZ",
      "originalText": "ต้นทุนวัตถุดิบ (เสื้อเปล่า, เส้นพลาสติก), ค่าไฟและค่าบำรุงรักษาเครื่องพิมพ์/3D Printer, ค่าการตลาดออนไลน์,ค่าเช่าคลังสินค้า, ค่าเช่า Hosting Domain, เงินเดือนทีมงานและแอดมิน, ภาษีฯ",
      "autoResize": true,
      "lineHeight": 1.35
    },
