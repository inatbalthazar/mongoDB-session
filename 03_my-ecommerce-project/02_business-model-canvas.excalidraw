    {
      "id": "y6aNC1d2hGUBtUfzc2dOJ",
      "type": "text",
      "x": 1329.3043679860893,
      "y": 273.4698850001613,
      "width": 232.8008575439453,
      "height": 194.4,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
